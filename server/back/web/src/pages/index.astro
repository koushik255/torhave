---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Video Player</title>
  </head>
  <body class="bg-[#0f0f0f] text-white min-h-screen font-sans">
    <div class="max-w-6xl mx-auto p-5">
      <h1 class="mb-5 text-2xl font-semibold">Movies</h1>
      <div class="grid grid-cols-[280px_1fr] gap-5">
        <div id="movie-list" class="bg-[#1a1a1a] rounded-lg p-4 max-h-[80vh] overflow-y-auto">
          Loading...
        </div>
        <div>
          <div class="bg-black rounded-lg overflow-hidden">
            <div id="placeholder" class="flex items-center justify-center h-[400px] text-gray-500">
              Select a movie to play
            </div>
            <video id="video-player" class="w-full hidden" controls></video>
          </div>
          <button id="screenshot-btn" class="hidden mt-3 bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded transition-colors">
            Screenshot
          </button>
        </div>
      </div>
    </div>

    <dialog id="screenshot-dialog" class="bg-[#1a1a1a] rounded-lg p-4 text-white backdrop:bg-black/50">
      <h2 class="text-lg mb-3 font-semibold">Screenshot</h2>
      <img id="screenshot-img" class="max-w-full max-h-[70vh] rounded mb-3" />
      <div class="flex gap-2 justify-end">
        <button id="save-screenshot" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded transition-colors">
          Save
        </button>
        <button id="close-dialog" class="bg-gray-600 hover:bg-gray-700 px-4 py-2 rounded transition-colors">
          Close
        </button>
      </div>
    </dialog>

    <canvas id="screenshot-canvas" class="hidden"></canvas>

    <script src="../scripts/video-player.client.ts"></script>
  </body>
</html>
